# NM-Play Server Configuration
# Copy to .env and fill in values — NEVER commit .env to git

# Secret key for JWT tokens
NM_API_SECRET=

# NetworkMemories auth endpoint (to validate NM account tokens)
NM_AUTH_URL=https://networkmemories.com/api/auth/validate

# Server ports (defaults)
PORT_SLP=11451
PORT_L2=11452
PORT_PSP=27312
PORT_API=8080
